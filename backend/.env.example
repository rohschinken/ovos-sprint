NODE_ENV=development
PORT=3001
DATABASE_URL=./data/ovos-sprint.db
JWT_SECRET=your-secret-key-change-in-production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# Email Configuration
# -------------------
# Development (Mailpit - no authentication required)
# SMTP_HOST=mailpit
# SMTP_PORT=587
# For port 587 (STARTTLS):
# SMTP_SECURE=false
# For port 465 (TLS):
# SMTP_SECURE=true
# SMTP_USER=SMTP_Injection
# SMTP_PASSWORD=your-sparkpost-api-key
# SMTP_FROM_EMAIL=noreply@yourdomain.com
# SMTP_FROM_NAME=ovos Sprint 🏃‍♂️‍➡️

# Google SSO (optional)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_ALLOWED_DOMAIN=yourcompany.com  # Optional: restrict to a specific Google Workspace domain

# Database Seeding (optional - for non-interactive deployment)
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-secure-password
